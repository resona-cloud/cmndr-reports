{
  "outputDirectory": "public",
  "functions": {
    "api/report.js": { "maxDuration": 30 },
    "api/email.js": { "maxDuration": 30 },
    "api/pages.js": { "maxDuration": 30 },
    "api/auth.js": { "maxDuration": 10 },
    "api/audio.js": { "maxDuration": 30 },
    "api/goal.js": { "maxDuration": 10 },
    "api/health.js": { "maxDuration": 30 },
    "api/onboard.js": { "maxDuration": 30 },
    "api/ask.js": { "maxDuration": 30 },
    "api/actions.js": { "maxDuration": 15 },
    "api/pipeline.js": { "maxDuration": 30 },
    "api/connections.js": { "maxDuration": 60 }
  },
  "rewrites": [
    { "source": "/api/notifications", "destination": "/api/actions?_type=notifications" },
    { "source": "/api/notifications/:path*", "destination": "/api/actions?_type=notifications" },
    { "source": "/workbench", "destination": "/workbench.html" },
    { "source": "/app", "destination": "/app.html" },
    { "source": "/operations", "destination": "/app.html" },
    { "source": "/marketing", "destination": "/app.html" },
    { "source": "/finance", "destination": "/app.html" },
    { "source": "/optimization", "destination": "/app.html" },
    { "source": "/hub", "destination": "/hub.html" },
    { "source": "/connections", "destination": "/connections.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/", "destination": "/index.html" }
  ]
}
